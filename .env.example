# ══════════════════════════════════════════════
#  amnezia-setup — configuration
#  Copy to .env and fill in your values.
# ══════════════════════════════════════════════

# ── Server ────────────────────────────────────
ENDPOINT=                     # Public IP or domain of your homelab
SERVER_PORT=                  # UDP port (e.g. 51820)
HOST_IFACE=enp1s0             # Host NIC connected to OpenWrt
DNS=192.168.1.1               # OpenWrt DNS — required for Podkop fakeip routing

# ── VPN network ───────────────────────────────
VPN_PREFIX=10.8.1             # /24 prefix — clients get .1, .2, ...

# ── Docker ────────────────────────────────────
CONTAINER_NAME=amnezia-awg
DOCKER_NET=amnezia-net
DOCKER_BRIDGE=amn0
IMAGE=amneziavpn/amneziawg-go
CONFIG_DIR=/opt/amnezia/awg

# ── Amnezia obfuscation (shared by all clients) ──
JC=6
JMIN=10
JMAX=50
S1=45
S2=82
S3=56
S4=15

# ══════════════════════════════════════════════
#  Generated by setup — do not edit manually
# ══════════════════════════════════════════════
SERVER_PRIVKEY=
SERVER_PUBKEY=
PSK=
H1=
H2=
H3=
H4=
