# ══════════════════════════════════════════════
#  homelab — configuration
#  Copy to .env and fill in your values.
# ══════════════════════════════════════════════

# ── AmneziaWG ─────────────────────────────────
ENDPOINT=                      # Public IP or domain of your homelab
SERVER_PORT=51820               # UDP port
HOST_IFACE=enp1s0              # Host NIC connected to OpenWrt
DNS=192.168.1.1                # OpenWrt DNS — required for Podkop fakeip routing

# ── VPN network ───────────────────────────────
VPN_PREFIX=10.8.1              # /24 prefix — server gets .1, clients get .2, .3, ...

# ── Docker ────────────────────────────────────
CONTAINER_NAME=amnezia-awg
IMAGE=amneziavpn/amneziawg-go  # https://hub.docker.com/r/amneziavpn/amneziawg-go
CONFIG_DIR=/opt/amnezia/awg

# ── Amnezia obfuscation (shared by all clients) ──
JC=6
JMIN=10
JMAX=50
S1=45
S2=82
S3=56
S4=15

# ══════════════════════════════════════════════
#  Generated by amnezia setup — do not edit manually
# ══════════════════════════════════════════════
SERVER_PRIVKEY=
SERVER_PUBKEY=
PSK=
H1=
H2=
H3=
H4=

# ── Headscale ─────────────────────────────────
SERVER_URL=                    # e.g. https://headscale.example.com
HEADSCALE_PORT=8080
HEADSCALE_GRPC_PORT=50443
HEADSCALE_CONTAINER=headscale
HEADSCALE_IMAGE=headscale/headscale:latest
HEADSCALE_CONFIG_DIR=/opt/headscale/config
HEADSCALE_DATA_DIR=/opt/headscale/data
